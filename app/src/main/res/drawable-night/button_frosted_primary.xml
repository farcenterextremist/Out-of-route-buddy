<?xml version="1.0" encoding="utf-8"?>
<!-- Frosted-glass primary (dark mode): cool-slate gradient + inner highlight. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#252830" />
            <corners android:radius="4dp" />
            <stroke android:width="1dp" android:color="#10FFFFFF" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#282C32"
                        android:endColor="#14161A"
                        android:angle="270" />
                    <corners android:radius="4dp" />
                    <stroke android:width="1dp" android:color="#21FFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#32363C"
                        android:endColor="#1C1E24"
                        android:angle="270" />
                    <corners android:radius="4dp" />
                    <stroke android:width="1dp" android:color="#21FFFFFF" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#29FFFFFF"
                        android:centerColor="#00FFFFFF"
                        android:endColor="#00000000"
                        android:angle="270" />
                    <corners android:radius="4dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
