<?xml version="1.0" encoding="utf-8"?>
<!-- Monochrome removed: using full gradient as monochrome caused icon to render all black
     when Themed Icons are enabled (Android 13+). Foreground gradient + truck now displays correctly. -->
<adaptive-icon xmlns:android="http://schemas.android.com/apk/res/android">
    <background android:drawable="@drawable/ic_launcher_background" />
    <!-- Reference PNG directly (bitmap wrapper can cause black rendering on some devices) -->
    <foreground android:drawable="@drawable/ic_launcher_foreground_src" />
</adaptive-icon>