<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:gravity="center_vertical"
    android:orientation="horizontal">

    <TextView
        android:id="@+id/breakdown_label"
        android:layout_width="110dp"
        android:layout_height="wrap_content"
        android:textColor="@color/text_secondary_adaptive"
        android:textSize="13sp"
        tools:text="OOR Efficiency" />

    <!-- Continuous tire track streak -->
    <FrameLayout
        android:layout_width="0dp"
        android:layout_height="12dp"
        android:layout_marginHorizontal="8dp"
        android:layout_weight="1"
        android:background="@drawable/bg_tire_tread_track">

        <View
            android:id="@+id/breakdown_fill"
            android:layout_width="0dp"
            android:layout_height="match_parent"
            android:background="@drawable/bg_tire_tread_fill"
            tools:layout_width="82dp" />
    </FrameLayout>

    <TextView
        android:id="@+id/breakdown_value"
        android:layout_width="30dp"
        android:layout_height="wrap_content"
        android:gravity="end"
        android:textColor="@color/text_primary_adaptive"
        android:textSize="13sp"
        android:textStyle="bold"
        tools:text="82" />

    <TextView
        android:id="@+id/breakdown_weight"
        android:layout_width="32dp"
        android:layout_height="wrap_content"
        android:layout_marginStart="4dp"
        android:gravity="end"
        android:textColor="@color/accent"
        android:textSize="10sp"
        tools:text="40%" />
</LinearLayout>
