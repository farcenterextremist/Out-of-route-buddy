<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="24dp"
    android:background="@drawable/card_white_rounded">

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Select Period Template"
        android:textAppearance="@style/TextAppearance.OORB.SectionTitle"
        android:layout_marginBottom="16dp" />

    <TextView
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="Choose how to group and calculate your trip statistics:"
        android:textSize="14sp"
        android:textColor="@color/text_secondary_adaptive"
        android:layout_marginBottom="16dp" />

    <RadioGroup
        android:id="@+id/template_select_radio_group"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">
        
        <RadioButton
            android:id="@+id/radio_template_standard"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/template_standard_label"
            android:layout_marginBottom="8dp" />
            
        <RadioButton
            android:id="@+id/radio_template_custom"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/template_custom_label" />
    </RadioGroup>

</LinearLayout> 