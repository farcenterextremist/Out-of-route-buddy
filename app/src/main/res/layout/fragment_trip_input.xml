<?xml version="1.0" encoding="utf-8"?>
<!-- #8 Production: CoordinatorLayout + AppBarLayout for scrolling top toolbar -->
<androidx.coordinatorlayout.widget.CoordinatorLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/background_page"
    tools:context="com.example.outofroutebuddy.presentation.ui.trip.TripInputFragment">

    <com.google.android.material.appbar.AppBarLayout
        android:id="@+id/app_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:elevation="0dp">

        <!-- Toolbar: scrolls with content (scroll|enterAlways) - Production #8 -->
        <include
            android:id="@+id/custom_toolbar_layout"
            layout="@layout/custom_toolbar"
            android:layout_width="match_parent"
            android:layout_height="160dp"
            app:layout_scrollFlags="scroll|enterAlways" />
    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:fillViewport="true"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical">

        <androidx.constraintlayout.widget.ConstraintLayout
            android:id="@+id/trip_input_fragment"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:padding="@dimen/oorb_space_16">

        <!-- Trip form: miles row → pickup → dropoff → start/pause (start below all fields). -->
        <LinearLayout
            android:id="@+id/trip_input_top_row"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/oorb_space_16">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false">

                <EditText
                    android:id="@+id/loaded_miles_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/oorb_space_8"
                    android:hint="@string/loaded_miles"
                    android:inputType="numberDecimal"
                    android:digits="0123456789."
                    android:maxLength="10"
                    android:background="@drawable/input_field_outlined"
                    android:padding="12dp"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary_adaptive"
                    android:textColorHint="@color/hint_adaptive"
                    android:letterSpacing="0.01"
                    android:contentDescription="@string/loaded_miles_input_description"
                    android:importantForAccessibility="yes"
                    android:minHeight="48dp"
                    android:elevation="3dp"/>

                <EditText
                    android:id="@+id/bounce_miles_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/bounce_miles"
                    android:inputType="numberDecimal"
                    android:digits="0123456789."
                    android:maxLength="10"
                    android:background="@drawable/input_field_outlined"
                    android:padding="12dp"
                    android:gravity="center"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary_adaptive"
                    android:textColorHint="@color/hint_adaptive"
                    android:letterSpacing="0.01"
                    android:contentDescription="@string/bounce_miles_input_description"
                    android:importantForAccessibility="yes"
                    android:minHeight="48dp"
                    android:elevation="3dp"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:baselineAligned="false"
                android:layout_marginTop="@dimen/oorb_space_8">

                <AutoCompleteTextView
                    android:id="@+id/pickup_address_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:layout_marginEnd="@dimen/oorb_space_8"
                    android:hint="@string/pickup_address_hint"
                    android:inputType="textPostalAddress|textCapWords"
                    android:background="@drawable/input_field_outlined"
                    android:padding="12dp"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary_adaptive"
                    android:textColorHint="@color/hint_adaptive"
                    android:letterSpacing="0.01"
                    android:maxLines="2"
                    android:minHeight="48dp"
                    android:gravity="center_vertical"
                    android:contentDescription="@string/pickup_address_input_description"
                    android:importantForAccessibility="yes"
                    android:elevation="3dp"
                    android:completionThreshold="1"
                    android:dropDownWidth="match_parent"/>

                <AutoCompleteTextView
                    android:id="@+id/dropoff_address_input"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:hint="@string/dropoff_address_hint"
                    android:inputType="textPostalAddress|textCapWords"
                    android:background="@drawable/input_field_outlined"
                    android:padding="12dp"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary_adaptive"
                    android:textColorHint="@color/hint_adaptive"
                    android:letterSpacing="0.01"
                    android:maxLines="2"
                    android:minHeight="48dp"
                    android:gravity="center_vertical"
                    android:contentDescription="@string/dropoff_address_input_description"
                    android:importantForAccessibility="yes"
                    android:elevation="3dp"
                    android:completionThreshold="1"
                    android:dropDownWidth="match_parent"/>
            </LinearLayout>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center"
                android:layout_marginTop="@dimen/oorb_space_16">

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/start_trip_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:minWidth="180dp"
                    android:minHeight="52dp"
                    android:text="@string/start_trip"
                    android:textColor="@android:color/white"
                    android:textStyle="bold"
                    android:textSize="17sp"
                    android:letterSpacing="0.04"
                    android:contentDescription="@string/start_trip_button_description"
                    android:importantForAccessibility="yes"
                    app:backgroundTint="@color/button_primary_tint"
                    app:cornerRadius="6dp"
                    app:elevation="12dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/button_gloss_stroke"
                    android:stateListAnimator="@null"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/pause_button"
                    android:layout_width="52dp"
                    android:layout_height="52dp"
                    android:layout_marginStart="@dimen/oorb_space_8"
                    android:text=""
                    app:icon="@drawable/ic_pause_adaptive"
                    app:iconTint="@android:color/white"
                    android:contentDescription="Pause trip tracking"
                    android:importantForAccessibility="yes"
                    app:backgroundTint="@color/button_primary_tint"
                    app:cornerRadius="6dp"
                    app:elevation="12dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/button_gloss_stroke"
                    android:stateListAnimator="@null"
                    android:visibility="gone"
                    app:iconSize="20dp"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"/>
            </LinearLayout>
        </LinearLayout>

        <ProgressBar
            android:id="@+id/progress_bar"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:visibility="gone"
            android:contentDescription="@string/progress_bar_description"
            android:importantForAccessibility="yes"
            app:layout_constraintTop_toBottomOf="@id/trip_input_top_row"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="8dp"/>

        <TextView
            android:id="@+id/todays_info_title"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="@string/todays_info"
            android:textSize="18sp"
            android:textStyle="bold"
            android:textColor="@color/text_primary_adaptive"
            app:layout_constraintTop_toBottomOf="@id/trip_input_top_row"
            app:layout_constraintStart_toStartOf="parent"
            android:layout_marginTop="@dimen/oorb_space_16" />

        <LinearLayout
            android:id="@+id/todays_info_card"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_white_rounded"
            android:padding="@dimen/oorb_space_16"
            android:layout_marginTop="@dimen/oorb_space_8"
            app:layout_constraintTop_toBottomOf="@id/todays_info_title"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:elevation="@dimen/oorb_card_elevation">

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/oorb_space_8">
                <TextView
                    android:id="@+id/total_miles_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/total_miles"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary_adaptive"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"/>
                <TextView
                    android:id="@+id/total_miles_output"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="0.0"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary_adaptive"
                    android:contentDescription="@string/total_miles_description"
                    android:importantForAccessibility="yes"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/total_miles_label"
                    android:layout_marginStart="@dimen/oorb_space_8"/>
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/color_outline_variant" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="@dimen/oorb_space_8">
                <TextView
                    android:id="@+id/oor_miles_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/oor_miles"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary_adaptive"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"/>
                <TextView
                    android:id="@+id/oor_miles_output"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="0.0"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary_adaptive"
                    android:contentDescription="@string/oor_miles_description"
                    android:importantForAccessibility="yes"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/oor_miles_label"
                    android:layout_marginStart="8dp"/>
            </RelativeLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/divider_adaptive" />

            <RelativeLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:paddingVertical="4dp">
                <TextView
                    android:id="@+id/oor_percent_label"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/oor_percent"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary_adaptive"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"/>
                <TextView
                    android:id="@+id/oor_percentage_output"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="0.0%"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary_adaptive"
                    android:contentDescription="@string/oor_percentage_description"
                    android:importantForAccessibility="yes"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"
                    android:layout_toEndOf="@id/oor_percent_label"
                    android:layout_marginStart="@dimen/oorb_space_8"/>
            </RelativeLayout>

            <View
                android:id="@+id/ludacris_divider"
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:visibility="gone"
                android:background="@color/color_outline_variant" />

            <RelativeLayout
                android:id="@+id/ludacris_tz_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:paddingVertical="@dimen/oorb_space_8">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/trip_card_time_zones"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary_adaptive"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"/>
                <TextView
                    android:id="@+id/ludacris_tz_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="2"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary_adaptive"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/ludacris_elev_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:paddingVertical="4dp">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/trip_card_elevation"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary_adaptive"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"/>
                <TextView
                    android:id="@+id/ludacris_elev_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="420–890 ft"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary_adaptive"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>

            <RelativeLayout
                android:id="@+id/ludacris_speed_row"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:visibility="gone"
                android:paddingVertical="@dimen/oorb_space_8">
                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/trip_card_max_speed"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary_adaptive"
                    android:layout_alignParentStart="true"
                    android:layout_centerVertical="true"/>
                <TextView
                    android:id="@+id/ludacris_speed_value"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    tools:text="72 mph"
                    android:textSize="15sp"
                    android:textColor="@color/text_primary_adaptive"
                    android:layout_alignParentEnd="true"
                    android:layout_centerVertical="true"/>
            </RelativeLayout>
        </LinearLayout>

        <com.google.android.material.button.MaterialButton
            android:id="@+id/statistics_button"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:text="@string/statistics"
            app:icon="@drawable/ic_arrow_up"
            app:iconGravity="textEnd"
            app:iconTint="@android:color/white"
            android:textColor="@android:color/white"
            android:textStyle="bold"
            android:textSize="16sp"
            android:letterSpacing="0.04"
            android:minHeight="52dp"
            android:contentDescription="@string/statistics_button_description"
            android:importantForAccessibility="yes"
            app:backgroundTint="@color/button_secondary_tint"
            app:cornerRadius="6dp"
            app:elevation="10dp"
            app:strokeWidth="1dp"
            app:strokeColor="@color/button_gloss_stroke"
            android:stateListAnimator="@null"
            app:layout_constraintTop_toBottomOf="@id/todays_info_card"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            android:layout_marginTop="@dimen/oorb_space_24"/>

        <!-- Expandable Statistics Section -->
        <LinearLayout
            android:id="@+id/statistics_content"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:background="@drawable/card_white_rounded"
            android:padding="@dimen/oorb_space_16"
            android:layout_marginTop="@dimen/oorb_space_16"
            android:visibility="gone"
            tools:visibility="visible"
            android:elevation="@dimen/oorb_card_elevation"
            app:layout_constraintTop_toBottomOf="@id/statistics_button"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent">

            <TextView
                android:id="@+id/selected_period_title"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="@string/statistics_selected_period_label"
                android:textSize="16sp"
                android:textStyle="bold"
                android:textColor="@color/text_primary_adaptive"
                android:layout_marginBottom="4dp"/>

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:gravity="center_vertical"
                android:layout_marginBottom="12dp">

                <TextView
                    android:id="@+id/selected_period_value"
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/statistics_placeholder"
                    android:textSize="16sp"
                    android:textColor="@color/text_primary_adaptive"/>

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/statistics_calendar_button"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="@string/statistics_change_period_button"
                    android:textAllCaps="false"
                    android:textSize="15sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.04"
                    android:minWidth="88dp"
                    android:minHeight="48dp"
                    android:paddingStart="24dp"
                    android:paddingEnd="24dp"
                    android:textColor="@android:color/white"
                    app:backgroundTint="@color/button_secondary_tint"
                    app:cornerRadius="6dp"
                    app:elevation="10dp"
                    app:strokeWidth="1dp"
                    app:strokeColor="@color/button_gloss_stroke"
                    android:stateListAnimator="@null"
                    android:contentDescription="@string/statistics_calendar_button_description"/>
            </LinearLayout>

            <View
                android:layout_width="match_parent"
                android:layout_height="1dp"
                android:background="@color/color_outline_variant"
                android:layout_marginBottom="@dimen/oorb_space_12"/>

            <!-- Month Stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/month_statistics"
                    android:textColor="@color/text_primary_adaptive"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/month_delete_button"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="8dp"
                    android:contentDescription="@string/delete_month_trips_description"
                    android:minWidth="44dp"
                    android:minHeight="44dp"
                    android:text=""
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:backgroundTint="@android:color/transparent"
                    app:icon="@drawable/ic_delete_trash"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="22dp"
                    app:iconTint="@color/text_secondary_adaptive"
                    app:strokeWidth="0dp"
                    app:rippleColor="#40FF0000" />
            </LinearLayout>
            <include layout="@layout/statistics_row" android:id="@+id/monthly_stats"/>

            <!-- Year Stats -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginTop="16dp"
                android:layout_marginBottom="8dp"
                android:gravity="center_vertical"
                android:orientation="horizontal">

                <TextView
                    android:layout_width="0dp"
                    android:layout_height="wrap_content"
                    android:layout_weight="1"
                    android:text="@string/year_statistics"
                    android:textColor="@color/text_primary_adaptive"
                    android:textSize="18sp"
                    android:textStyle="bold" />

                <com.google.android.material.button.MaterialButton
                    android:id="@+id/year_delete_button"
                    style="@style/Widget.MaterialComponents.Button.OutlinedButton"
                    android:layout_width="44dp"
                    android:layout_height="44dp"
                    android:layout_marginStart="@dimen/oorb_space_8"
                    android:contentDescription="@string/delete_year_trips_description"
                    android:minWidth="44dp"
                    android:minHeight="44dp"
                    android:text=""
                    android:insetTop="0dp"
                    android:insetBottom="0dp"
                    app:backgroundTint="@android:color/transparent"
                    app:icon="@drawable/ic_delete_trash"
                    app:iconGravity="textStart"
                    app:iconPadding="0dp"
                    app:iconSize="22dp"
                    app:iconTint="@color/text_secondary_adaptive"
                    app:strokeWidth="0dp"
                    app:rippleColor="#40FF0000" />
            </LinearLayout>
            <include layout="@layout/statistics_row" android:id="@+id/yearly_stats"/>

        </LinearLayout>

        </androidx.constraintlayout.widget.ConstraintLayout>

        </LinearLayout>
    </androidx.core.widget.NestedScrollView>
</androidx.coordinatorlayout.widget.CoordinatorLayout> 