<?xml version="1.0" encoding="utf-8"?>
<androidx.constraintlayout.widget.ConstraintLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp"
    android:background="@drawable/dialog_background">

    <!-- Toolbar: title (left) + X close button (top right) -->
    <TextView
        android:id="@+id/calendar_title"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/statistics_select_day"
        android:textSize="18sp"
        android:textStyle="bold"
        android:textColor="@color/text_primary_adaptive"
        android:gravity="center_vertical"
        android:layout_marginEnd="8dp"
        android:layout_marginBottom="16dp"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintBottom_toBottomOf="@id/calendar_close_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toStartOf="@id/calendar_close_button"
        app:layout_constraintHorizontal_bias="0"/>

    <ImageButton
        android:id="@+id/calendar_close_button"
        android:layout_width="48dp"
        android:layout_height="48dp"
        android:src="@drawable/ic_calendar_close_adaptive"
        android:background="?attr/selectableItemBackgroundBorderless"
        android:contentDescription="@string/close"
        android:scaleType="centerInside"
        app:layout_constraintTop_toTopOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <com.prolificinteractive.materialcalendarview.MaterialCalendarView
        android:id="@+id/calendar_view"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:layout_marginTop="8dp"
        android:layout_marginBottom="16dp"
        app:mcv_showOtherDates="all"
        app:mcv_selectionColor="@color/calendar_selection_adaptive"
        app:mcv_leftArrow="@drawable/ic_calendar_arrow_left"
        app:mcv_rightArrow="@drawable/ic_calendar_arrow_right"
        app:mcv_dateTextAppearance="@style/CalendarDateTextAppearance"
        app:mcv_headerTextAppearance="@style/CalendarHeaderTextAppearance"
        app:layout_constraintTop_toBottomOf="@id/calendar_close_button"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

    <TextView
        android:id="@+id/calendar_hint"
        android:layout_width="0dp"
        android:layout_height="wrap_content"
        android:text="@string/calendar_click_hint"
        android:textSize="12sp"
        android:textColor="@color/text_secondary_adaptive"
        android:gravity="center"
        android:layout_marginBottom="8dp"
        app:layout_constraintTop_toBottomOf="@id/calendar_view"
        app:layout_constraintStart_toStartOf="parent"
        app:layout_constraintEnd_toEndOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
