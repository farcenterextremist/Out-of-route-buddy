<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Material Design color scheme -->
    <color name="primary">#FF000000</color>
    <color name="primary_dark">#FF000000</color>
    <color name="accent">#9E9E9E</color>
    <color name="accent_dark">#757575</color>
    
    <!-- Original colors -->
    <color name="purple_200">#FFBB86FC</color>
    <color name="purple_500">#FF6200EE</color>
    <color name="purple_700">#FF3700B3</color>
    <color name="teal_200">@color/accent</color>
    <color name="teal_700">@color/accent_dark</color>
    <color name="black">#FF000000</color>
    <color name="white">#FFFFFFFF</color>
    
    <!-- Error color -->
    <color name="error">#FFB00020</color>
    
    <!-- Light gray background -->
    <color name="light_gray_background">#F5F5F5</color>

    <!-- Flat page background (calm, neutral, adaptive) -->
    <color name="page_background">#F5F5F5</color>

    <!-- M3-style semantic aliases (Phase E — cohesive tokens without dynamic color) -->
    <color name="color_surface_container">#F0F4F4</color>
    <color name="color_outline_variant">#E0E0E0</color>
    
    <!-- Adaptive colors for light mode -->
    <color name="text_primary_adaptive">#FF000000</color>
    <color name="text_secondary_adaptive">#757575</color>
    <color name="hint_adaptive">#757575</color>

    <!-- Settings dialog - high-contrast text (darker black in light mode) -->
    <color name="settings_text_primary">#FF000000</color>
    <color name="settings_text_secondary">#FF212121</color>
    <color name="background_adaptive">#FFFFFF</color>
    <color name="card_background_adaptive">#FFFFFF</color>
    <color name="divider_adaptive">#E0E0E0</color>
    
    <!-- Material/Compose expected colors (referenced by libraries) -->
    <color name="surface">#FFFFFF</color>
    <color name="text_primary">#FF000000</color>
    <color name="background">#FFFFFF</color>
    
    <!-- Dialog colors -->
    <color name="primary_color">@color/purple_500</color>
    <color name="primary_text">@color/text_primary_adaptive</color>
    <color name="secondary_text">@color/text_secondary_adaptive</color>

    <!-- Brand chrome (toolbar, drawer header, settings app bar) -->
    <color name="brand_header_top">#1A4A44</color>
    <color name="brand_header_deep">#0F2E2A</color>
    <color name="brand_header_night">#0A1F1C</color>
    <color name="brand_on_header">#F5FFFE</color>
    <color name="brand_on_header_muted">#B2DFDB</color>
    <color name="settings_pref_icon">#FF212121</color>
    <color name="settings_appbar">@color/brand_header_deep</color>

    <!-- Navigation drawer list surface -->
    <color name="nav_drawer_surface">#F8FAFA</color>

    <!-- Calendar stat cards: trips that look stale or unusually short/long -->
    <color name="trip_review_flag_stroke">#CC6600</color>
    <color name="trip_review_flag_card_fill">#FFFFF3E0</color>
    <!-- Light edge on grey buttons (light mode “gloss”) -->
    <color name="button_gloss_stroke">#C8C8C8</color>
    <!-- Calendar selection highlight (adaptive) -->
    <color name="calendar_selection_adaptive">#9E9E9E</color>
    <!-- Calendar: days with trips (Material Orange 500, matches TodayWithTripsDecorator) -->
    <color name="calendar_day_has_trip_fill">#FFFF9800</color>
    <!-- Calendar history: blended OOR tier markers (MaterialCalendarView day cells) -->
    <color name="calendar_trip_oor_good_fill">#2E7D32</color>
    <color name="calendar_trip_oor_good_stroke">#FFFFFF</color>
    <color name="calendar_trip_oor_warn_fill">#4DFFEB3B</color>
    <color name="calendar_trip_oor_warn_stroke">#FFD600</color>
    <color name="calendar_trip_oor_bad_fill">#40FFCDD2</color>
    <color name="calendar_trip_oor_bad_stroke">#7F0000</color>
    <!-- Trip-by-date dialog: stat cards + day summary (OOR tier chrome) -->
    <!-- GREEN tier (OOR 10% or less): strong green card -->
    <color name="history_trip_oor_good_card_fill">#C8E6C9</color>
    <color name="history_trip_oor_good_card_stroke">#2E7D32</color>
    <color name="history_trip_oor_good_oor_text">#1B5E20</color>
    <!-- ORANGE tier (OOR 10-14%): clearly orange card -->
    <color name="history_trip_oor_warn_card_fill">#FFE0B2</color>
    <color name="history_trip_oor_warn_card_stroke">#E65100</color>
    <color name="history_trip_oor_warn_oor_text">#BF360C</color>
    <!-- DEEP RED tier (OOR over 14%): bold red card -->
    <color name="history_trip_oor_bad_card_fill">#FFCDD2</color>
    <color name="history_trip_oor_bad_card_stroke">#B71C1C</color>
    <color name="history_trip_oor_bad_oor_text">#7F0000</color>

    <!-- Ranking tier badge backgrounds -->
    <color name="tier_diamond_bg">#B9F2FF</color>
    <color name="tier_diamond_text">#004D40</color>
    <color name="tier_platinum_bg">#E5E4E2</color>
    <color name="tier_platinum_text">#212121</color>
    <color name="tier_gold_bg">#FFD700</color>
    <color name="tier_gold_text">#33200A</color>
    <color name="tier_silver_bg">#C0C0C0</color>
    <color name="tier_silver_text">#212121</color>
    <color name="tier_bronze_bg">#CD7F32</color>
    <color name="tier_bronze_text">#FFF8E1</color>

    <!-- Ranking breakdown bar colors -->
    <color name="bar_oor_efficiency">#2E7D32</color>
    <color name="bar_consistency">#1565C0</color>
    <color name="bar_trip_volume">#E65100</color>
    <color name="bar_gps_quality">#6A1B9A</color>
    <color name="bar_route_discipline">#00695C</color>
</resources>