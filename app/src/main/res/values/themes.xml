<?xml version="1.0" encoding="utf-8"?>
<resources>

    <style name="Theme.OutofRoutebuddy" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <!-- Primary brand color -->
        <item name="colorPrimary">@color/accent</item>
        <item name="colorPrimaryVariant">@color/accent_dark</item>
        <item name="colorOnPrimary">@color/white</item>
        <!-- Secondary brand color -->
        <item name="colorSecondary">@color/accent</item>
        <item name="colorSecondaryVariant">@color/accent_dark</item>
        <item name="colorOnSecondary">@color/black</item>
        <!-- Widget control colors: kills all teal -->
        <item name="colorAccent">@color/accent</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="colorControlActivated">@color/accent</item>
        <item name="colorControlHighlight">#20000000</item>
        <item name="android:colorControlActivated">@color/accent</item>
        <item name="android:colorControlHighlight">#20000000</item>
        <!-- Background / surface -->
        <item name="android:colorBackground">@color/background_adaptive</item>
        <item name="colorSurface">@color/background_adaptive</item>
        <!-- Status bar: dark road -->
        <item name="android:statusBarColor">@color/primary</item>
        <!-- Enable window content transitions -->
        <item name="android:windowActivityTransitions">true</item>
        <!-- Switch widget style override -->
        <item name="switchStyle">@style/OORBSwitch</item>
        <item name="switchPreferenceCompatStyle">@style/OORBSwitchPreference</item>
        <!-- Preferences: force accent into preference widgets -->
        <item name="preferenceTheme">@style/PreferenceThemeOverlay.OORB</item>
        <!-- Menu styling -->
        <item name="android:popupMenuStyle">@style/PopupMenuStyle</item>
    </style>

    <style name="Theme.Test" parent="Theme.MaterialComponents.Light.NoActionBar">
        <item name="android:windowBackground">@android:color/white</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">false</item>
        <item name="android:windowContentOverlay">@null</item>
    </style>

    <!-- Splash screen theme: black background with truck image -->
    <style name="Theme.OutofRoutebuddy.Splash" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="android:windowBackground">@drawable/splash_background</item>
        <item name="android:windowNoTitle">true</item>
        <item name="android:windowFullscreen">true</item>
        <item name="android:statusBarColor">@android:color/black</item>
        <item name="android:navigationBarColor">@android:color/black</item>
    </style>

    <!-- Menu style for visibility -->
    <style name="PopupMenuStyle" parent="Widget.MaterialComponents.PopupMenu">
        <item name="android:popupBackground">@android:color/white</item>
        <item name="android:textColor">@android:color/black</item>
    </style>

</resources>