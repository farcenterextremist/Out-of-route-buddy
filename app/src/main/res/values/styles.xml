<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="GreyGradientButton" parent="Widget.MaterialComponents.Button">
        <item name="android:textColor">@color/text_primary_adaptive</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:padding">12dp</item>
        <item name="android:stateListAnimator">@null</item>
        <item name="elevation">0dp</item>
        <item name="cornerRadius">8dp</item>
        <item name="android:background">@drawable/gradient_grey_button</item>
    </style>

    <style name="OORToolbarTitle" parent="TextAppearance.Widget.AppCompat.Toolbar.Title">
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">28sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:fontFamily">sans-serif-condensed</item>
        <item name="android:letterSpacing">0.05</item>
        <item name="android:shadowColor">#80000000</item>
        <item name="android:shadowDx">1</item>
        <item name="android:shadowDy">1</item>
        <item name="android:shadowRadius">2</item>
    </style>

    <!-- Calendar date text appearance -->
    <style name="CalendarDateTextAppearance" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textColor">@color/text_primary_adaptive</item>
        <item name="android:textSize">14sp</item>
    </style>

    <!-- Calendar month header - larger, bold text -->
    <style name="CalendarHeaderTextAppearance" parent="TextAppearance.MaterialComponents.Headline6">
        <item name="android:textColor">@color/text_primary_adaptive</item>
        <item name="android:textSize">24sp</item>
        <item name="android:textStyle">bold</item>
    </style>

    <!-- Settings dialog Help & Info - secondary style -->
    <style name="SettingsHelpButton" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/button_secondary_material</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:paddingTop">12dp</item>
        <item name="android:paddingBottom">12dp</item>
        <item name="android:paddingStart">24dp</item>
        <item name="android:paddingEnd">24dp</item>
    </style>

    <!-- Typography scale (Phase D) -->
    <style name="TextAppearance.OORB.SectionTitle" parent="TextAppearance.MaterialComponents.Subtitle1">
        <item name="android:textSize">15sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:textColor">@color/text_primary_adaptive</item>
        <item name="android:fontFamily">sans-serif-medium</item>
    </style>
    <style name="TextAppearance.OORB.Body" parent="TextAppearance.MaterialComponents.Body1">
        <item name="android:textSize">16sp</item>
        <item name="android:textColor">@color/text_primary_adaptive</item>
    </style>
    <style name="TextAppearance.OORB.BodySecondary" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">14sp</item>
        <item name="android:textColor">@color/text_secondary_adaptive</item>
    </style>
    <style name="TextAppearance.OORB.Caption" parent="TextAppearance.MaterialComponents.Caption">
        <item name="android:textSize">12sp</item>
        <item name="android:textColor">@color/text_secondary_adaptive</item>
    </style>

    <style name="OORBSwitch" parent="Widget.AppCompat.CompoundButton.Switch">
        <item name="thumbTint">@color/switch_thumb_tint</item>
        <item name="trackTint">@color/switch_track_tint</item>
    </style>

    <style name="OORBSwitchPreference" parent="Preference.SwitchPreferenceCompat.Material">
        <item name="android:widgetLayout">@layout/preference_widget_switch_compat</item>
    </style>

    <style name="PreferenceThemeOverlay.OORB" parent="PreferenceThemeOverlay">
        <item name="android:textColorPrimary">@color/text_primary_adaptive</item>
        <item name="android:textColorSecondary">@color/text_secondary_adaptive</item>
        <item name="colorAccent">@color/accent</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="colorControlActivated">@color/accent</item>
        <item name="android:colorControlActivated">@color/accent</item>
        <item name="colorControlNormal">@color/text_secondary_adaptive</item>
        <item name="colorControlHighlight">#20808080</item>
        <item name="android:colorControlHighlight">#20808080</item>
        <item name="colorPrimary">@color/accent</item>
        <item name="colorSecondary">@color/accent</item>
        <item name="android:alertDialogTheme">@style/OORBAlertDialog</item>
    </style>

    <style name="OORBAlertDialog" parent="ThemeOverlay.MaterialComponents.Dialog.Alert">
        <item name="colorAccent">@color/accent</item>
        <item name="colorControlActivated">@color/accent</item>
        <item name="android:colorAccent">@color/accent</item>
        <item name="android:colorControlActivated">@color/accent</item>
        <item name="buttonBarPositiveButtonStyle">@style/OORBAlertDialogButton</item>
        <item name="buttonBarNegativeButtonStyle">@style/OORBAlertDialogButton</item>
    </style>

    <style name="OORBAlertDialogButton" parent="Widget.MaterialComponents.Button.TextButton.Dialog">
        <item name="android:textColor">@color/text_primary_adaptive</item>
    </style>

    <!-- Drawer and Preference text: unified 14sp sans-serif -->
    <style name="TextAppearance.OORB.DrawerItem" parent="TextAppearance.MaterialComponents.Body2">
        <item name="android:textSize">14sp</item>
        <item name="android:fontFamily">sans-serif</item>
        <item name="android:textColor">@color/text_primary_adaptive</item>
    </style>

    <style name="OORBPrimaryDialogButton" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/button_primary_material</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:textStyle">bold</item>
        <item name="android:minHeight">48dp</item>
    </style>
    <style name="OORBSecondaryDialogButton" parent="Widget.MaterialComponents.Button">
        <item name="android:background">@drawable/button_secondary_material</item>
        <item name="backgroundTint">@null</item>
        <item name="android:textColor">@android:color/white</item>
        <item name="android:textSize">16sp</item>
        <item name="android:minHeight">48dp</item>
    </style>
</resources> 