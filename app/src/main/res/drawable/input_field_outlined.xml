<?xml version="1.0" encoding="utf-8"?>
<!-- Trip form fields: clear 8dp corners + 1dp outline for sharper definition (light/dark via color_outline_variant). -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <solid android:color="@color/card_background_adaptive" />
    <stroke
        android:width="1dp"
        android:color="@color/color_outline_variant" />
    <corners android:radius="4dp" />
</shape>
