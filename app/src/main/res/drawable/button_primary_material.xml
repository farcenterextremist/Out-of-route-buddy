<?xml version="1.0" encoding="utf-8"?>
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_pressed="true">
        <layer-list>
            <item android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#30000000" />
                    <corners android:radius="4dp" />
                </shape>
            </item>
            <item android:top="1dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#1A4A44"
                        android:endColor="#0F2E2A"
                        android:angle="270" />
                    <corners android:radius="4dp" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item android:top="2dp">
                <shape android:shape="rectangle">
                    <solid android:color="#22000000" />
                    <corners android:radius="4dp" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#22796F"
                        android:centerColor="#1A5D55"
                        android:endColor="#124840"
                        android:angle="270" />
                    <corners android:radius="4dp" />
                </shape>
            </item>
            <item android:top="0dp" android:bottom="0dp" android:left="0dp" android:right="0dp">
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#33FFFFFF"
                        android:centerColor="#00FFFFFF"
                        android:endColor="#00000000"
                        android:angle="270" />
                    <corners android:radius="4dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
