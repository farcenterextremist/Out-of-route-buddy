<?xml version="1.0" encoding="utf-8"?>
<!-- Frosted-glass secondary (light mode): cool-slate gradient, softer highlight. -->
<selector xmlns:android="http://schemas.android.com/apk/res/android">
    <item android:state_enabled="false">
        <shape android:shape="rectangle">
            <solid android:color="#282C32" />
            <corners android:radius="4dp" />
            <stroke android:width="1dp" android:color="#0CFFFFFF" />
        </shape>
    </item>
    <item android:state_pressed="true">
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#282D34"
                        android:endColor="#1C2026"
                        android:angle="270" />
                    <corners android:radius="4dp" />
                    <stroke android:width="1dp" android:color="#17FFFFFF" />
                </shape>
            </item>
        </layer-list>
    </item>
    <item>
        <layer-list>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#32373E"
                        android:endColor="#22262C"
                        android:angle="270" />
                    <corners android:radius="4dp" />
                    <stroke android:width="1dp" android:color="#17FFFFFF" />
                </shape>
            </item>
            <item>
                <shape android:shape="rectangle">
                    <gradient
                        android:startColor="#1CFFFFFF"
                        android:centerColor="#00FFFFFF"
                        android:endColor="#00000000"
                        android:angle="270" />
                    <corners android:radius="4dp" />
                </shape>
            </item>
        </layer-list>
    </item>
</selector>
