# Copy to .env and fill in. Do not commit .env.
# Optional: set COORDINATOR_DRY_RUN=1 to log sends without sending (tests / integration).
COORDINATOR_EMAIL_TO=your-email@example.com
COORDINATOR_EMAIL_FROM=your-email@example.com
# Dedicated bot: set COORDINATOR_EMAIL_FROM=bot@gmail.com, SMTP/IMAP to bot credentials; COORDINATOR_EMAIL_TO=your personal email

# Optional: alternate recipients for "send to coworker" / "email family"
# COORDINATOR_EMAIL_COWORKER=coworker@example.com
# COORDINATOR_EMAIL_FAMILY=family@example.com

# Optional: YouTube Data API v3 key for video/tutorial recommendations
# COORDINATOR_YOUTUBE_API_KEY=your-youtube-api-key
COORDINATOR_SMTP_HOST=smtp.gmail.com
COORDINATOR_SMTP_PORT=587
COORDINATOR_SMTP_USER=your-email@example.com
COORDINATOR_SMTP_PASSWORD=your-app-password

# read_replies.py: when COORDINATOR_EMAIL_TO is set, only messages FROM these addresses are considered.
# Use comma-separated list (e.g. personal@gmail.com,work@company.com) to accept replies from multiple addresses.
# Optional: for read_replies.py (IMAP). If omitted, SMTP user/password are used.
# COORDINATOR_IMAP_HOST=imap.gmail.com
# COORDINATOR_IMAP_PORT=993
# COORDINATOR_IMAP_USER=your-email@example.com
# COORDINATOR_IMAP_PASSWORD=your-app-password

# Optional: for coordinator_listener.py (open line while Cursor is online).
# LLM backend: auto (default, picks first available), openai, ollama, anthropic, transformers
# COORDINATOR_LISTENER_LLM_BACKEND=auto
# Use either OpenAI, Ollama (no API key), Anthropic, or Transformers (local SmolLM):
# COORDINATOR_LISTENER_OPENAI_API_KEY=sk-...
# COORDINATOR_LISTENER_OLLAMA_URL=http://localhost:11434
# ANTHROPIC_API_KEY=sk-ant-...
# Transformers (local SmolLM, no API key): pip install transformers accelerate torch
# COORDINATOR_LISTENER_LLM_BACKEND=transformers
# COORDINATOR_LISTENER_TRANSFORMERS_MODEL=HuggingFaceTB/SmolLM2-1.7B-Instruct
# COORDINATOR_LISTENER_OLLAMA_MODEL=llama3.2
# COORDINATOR_LISTENER_OLLAMA_TEMPERATURE=0.3
# COORDINATOR_LISTENER_OLLAMA_MAX_TOKENS=512
# COORDINATOR_LISTENER_OLLAMA_TIMEOUT=900
# OpenAI-compatible local server (vLLM, LM Studio): base URL and optional model override
# COORDINATOR_LISTENER_OPENAI_BASE_URL=http://localhost:8080/v1
# COORDINATOR_LISTENER_OPENAI_MODEL=qwen2.5-7b
# Better alternatives: qwen2.5:7b (faster, quality), mistral (fastest), qwen2.5:14b (best quality). See docs/agents/JARVEY_LLM_OPTIONS.md
#
# LLM Quick Wins — recommended settings for faster, more reliable Ollama replies. See docs/agents/JARVEY_LLM_QUICK_WINS.md
# COORDINATOR_LISTENER_OLLAMA_MODEL=qwen2.5:7b
# COORDINATOR_LISTENER_OLLAMA_FAST_MODEL=phi3:mini
# COORDINATOR_LISTENER_OLLAMA_TIMEOUT=900
# COORDINATOR_LISTENER_OLLAMA_TEMPERATURE=0.3
# COORDINATOR_LISTENER_OLLAMA_MAX_TOKENS=512
# JARVEY_PREWARM_OLLAMA=1
# COORDINATOR_FAST_CONTEXT_FOR_RECENT=1
# COORDINATOR_FAST_CONTEXT_CHARS=4000
# JARVEY_OLLAMA_STREAMING=1
# JARVEY_OLLAMA_FALLBACK_TO_OPENAI=1  # requires OPENAI_API_KEY
# COORDINATOR_LISTENER_INTERVAL_MINUTES=3
# COORDINATOR_LISTENER_MAX_REPLIES_PER_HOUR=6
# Send capability menu (5-10 options) on startup. Set to 0 to disable.
JARVEY_SEND_OPENER_ON_STARTUP=1
# Jarvey face: animate on startup (blink). Set to 1 to enable.
# JARVEY_ANIMATE_FACE=1
# Jarvey face: ANSI color in terminal (TTY only by default). Set to 1 to force.
# JARVEY_FACE_COLOR=1
# Jarvey face theme: auto | ascii | unicode (auto picks unicode on UTF-8 terminals)
# JARVEY_FACE_THEME=auto
# Inject capability options into prompt for follow-up suggestions (Jarvey Versatility)
# JARVEY_INJECT_CAPABILITY_OPTIONS=1
# JARVEY_COOLDOWN_SECONDS=120
# COORDINATOR_BOT_NAME=Jarvey
# Conversation memory for multi-turn threads (prepends recent exchanges to context)
# JARVEY_CONVERSATION_MEMORY=1
# JARVEY_CONVERSATION_MAX_EXCHANGES=5
# Live workflow documentation: append steps to jarvey_workflow.log (recommended for auditing)
# JARVEY_LOG=1
# Structured JSON logs to jarvey_workflow.log (machine-readable)
# JARVEY_STRUCTURED_LOG=1
# Retry for IMAP/SMTP transient failures (exponential backoff)
# JARVEY_MAX_RETRIES=3
# JARVEY_RETRY_DELAY=2
# Circuit breaker: LLM failure thresholds (skip compose after N failures)
# JARVEY_LLM_BACKOFF_THRESHOLD=3
# JARVEY_LLM_CIRCUIT_OPEN_THRESHOLD=5
# JARVEY_LLM_CIRCUIT_RESET_SECONDS=3600
# Template confidence threshold: route to LLM when below (default 0.7)
# JARVEY_TEMPLATE_CONFIDENCE_THRESHOLD=0.7
# Clarification flow: use unclear template for short/vague messages instead of LLM (default 1)
# JARVEY_CLARIFICATION_TEMPLATE=1
# Brevity detection: use brevity_detector module for unclear/short-body (optional)
# JARVEY_BREVITY_USE_DETECTOR=1
# If USE_DETECTOR=1, optionally use implicature-intent for non-whitelisted short messages (pip install implicature-intent)
# JARVEY_BREVITY_USE_IMPLICATURE=1
# RAG: embedding + vector search for "find anything about X" / "search the docs" (Option A: sentence-transformers)
# JARVEY_RAG_ENABLED=1
# JARVEY_RAG_INDEX_PATH=jarvey_embeddings.json
# JARVEY_RAG_EMBEDDING_MODEL=intfloat/e5-small-v2
# JARVEY_RAG_TOP_K=3
# JARVEY_RAG_CHUNK_SIZE=500
# Build index first: python build_rag_index.py
# Supported models: intfloat/e5-small-v2 (default), BAAI/bge-small-en-v1.5, BAAI/bge-base-en-v1.5, all-MiniLM-L6-v2
